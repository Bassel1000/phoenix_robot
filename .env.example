# .env template file (Do not commit your REAL .env to git)
# Copy this file to a new file named '.env' and put your real values there

# MQTT Setup
MQTT_USERNAME=username_here
MQTT_PASSWORD=your_real_hivemq_password_here
MQTT_BROKER=your_real_broker_url_here.s1.eu.hivemq.cloud

# Camera Setup
RTSP_URL=rtsp://phoenix:your_camera_password@192.168.1.20:554/stream1